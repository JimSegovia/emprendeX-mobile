# ============================================================
# RAILWAY — Producción
# ============================================================
# Copiar a .env.local o configurar en EAS Build / expo build.
# La API en Railway asigna la URL automáticamente. Usa la URL
# pública de tu servicio Railway (formato: api-production-xxxx.up.railway.app).
# ============================================================

EXPO_PUBLIC_API_TARGET=railway
EXPO_PUBLIC_API_RAILWAY_BASE_URL=https://api-production-xxxx.up.railway.app/api/v1

# ── Moneda ──────────────────────────────────────────────────
EXPO_PUBLIC_DEFAULT_CURRENCY_SYMBOL=S/

# ── UI ──────────────────────────────────────────────────────
EXPO_PUBLIC_PASSWORD_MIN_LENGTH=8
